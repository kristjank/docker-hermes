#!/usr/bin/env bash
# hermes — wrapper around docker compose for the hermes-agent container.
#
# Usage:
#   ./hermes <command> [args...]
#
# Run `./hermes help` for the full list.

set -euo pipefail

# Resolve script dir so `./hermes` works from anywhere.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE=(docker compose)

# --- colors (only if stdout is a TTY) ---
if [ -t 1 ]; then
    B=$'\033[1m'; DIM=$'\033[2m'; G=$'\033[32m'; Y=$'\033[33m'; R=$'\033[31m'; N=$'\033[0m'
else
    B=""; DIM=""; G=""; Y=""; R=""; N=""
fi

die()  { echo "${R}error:${N} $*" >&2; exit 1; }
info() { echo "${DIM}==>${N} $*"; }
ok()   { echo "${G}✓${N} $*"; }

# Name of the hermes-home volume (derived from compose project name).
volume_name() {
    echo "$(basename "$SCRIPT_DIR" | tr '[:upper:]' '[:lower:]' | tr -dc 'a-z0-9_-')_hermes-home"
}

# Read the currently-active profile name from the volume (set by
# `hermes profile use <name>`). Returns "default" if no active_profile
# file exists — i.e. hermes is using the default profile at the volume root.
active_profile_name() {
    docker run --rm --user 1000:1000 -v "$(volume_name):/h" alpine \
        sh -c 'cat /h/active_profile 2>/dev/null || echo default' 2>/dev/null \
        | tr -d '[:space:]'
}

# Resolve a profile name to its SOUL.md path inside the volume.
# Empty arg → active profile; "default" → /h/SOUL.md;
# otherwise /h/profiles/<name>/SOUL.md
soul_path_in_volume() {
    local profile="${1:-$(active_profile_name)}"
    if [ "$profile" = "default" ] || [ -z "$profile" ]; then
        echo "/h/SOUL.md"
    else
        echo "/h/profiles/${profile}/SOUL.md"
    fi
}

# Restart gateway if it's currently running — soul/config/env changes
# need a session restart to take effect for long-running messaging.
maybe_restart_gateway() {
    if docker compose ps --services --filter status=running 2>/dev/null | grep -q '^gateway$'; then
        info "restarting gateway to pick up changes"
        "${COMPOSE[@]}" restart gateway >/dev/null
    fi
}

# Edit a file inside the volume using EDITOR (default: vi).
# Supported: vi (built-in to alpine), nano (installed on-the-fly ~200KB).
# Usage: edit_in_volume "/h/config.yaml"
#        edit_in_volume "/h/profiles/foo/SOUL.md" "mkdir -p /h/profiles/foo"
edit_in_volume() {
    local file="$1"
    local pre="${2:-}"   # optional setup command (e.g. mkdir -p)
    local editor="${EDITOR:-vi}"
    local vol
    vol="$(volume_name)"

    case "$editor" in
        vi|vim)
            # vi is built-in to alpine — runs as uid 1000 directly.
            docker run --rm -it --user 1000:1000 -v "${vol}:/h" alpine \
                sh -c "${pre:+$pre && }vi ${file}"
            ;;
        nano)
            # nano needs `apk add` (root), so we run as root for the install,
            # then chown the edited file back to 1000:1000 after exit.
            docker run --rm -it -v "${vol}:/h" alpine \
                sh -c "apk add -q nano >/dev/null 2>&1 && ${pre:+$pre && }nano ${file}; chown -R 1000:1000 \$(dirname ${file})"
            ;;
        *)
            die "unsupported EDITOR='${editor}' — use vi or nano (e.g. EDITOR=nano ./hermes edit)"
            ;;
    esac
}

# Point a profile's terminal.cwd at the bind-mounted workspace so generated
# files (PDFs, reports, downloads) land on the host at ./workspace/<profile>/
# instead of inside the volume at /h/profiles/<profile>/.
# Also creates the host-side directory and restarts the gateway if running.
setup_profile_workspace() {
    local profile="${1:-$(active_profile_name)}"
    [ -z "$profile" ] && die "no profile given and no active profile set"

    local container_path="/home/hermes/workspace/${profile}"
    local config_path
    if [ "$profile" = "default" ]; then
        config_path="/h/config.yaml"
    else
        config_path="/h/profiles/${profile}/config.yaml"
    fi

    # Create the host side of the bind mount first.
    mkdir -p "${SCRIPT_DIR}/workspace/${profile}"

    # Patch terminal.cwd in the profile's config.yaml.
    docker run --rm --user 1000:1000 -v "$(volume_name):/h" alpine sh -c "
        if [ ! -f ${config_path} ]; then
            echo 'profile ${profile} has no config.yaml yet — run \`./hermes profile create ${profile} --clone\` or \`./hermes setup\` first' >&2
            exit 1
        fi
        sed -i 's|^  cwd:.*|  cwd: ${container_path}|' ${config_path}
    " || return 1

    ok "profile '${profile}' → ./workspace/${profile}/ (on host) ↔ ${container_path} (in container)"
    maybe_restart_gateway
}

# Sync a profile's "output" directories from the volume to ./workspace/<name>/.
# Necessary because hermes's higher-level skills (PDF generation, code gen,
# downloads) write to HERMES_HOME regardless of terminal.cwd. Run on demand.
#
# What gets pulled: every top-level file/dir under the profile's HERMES_HOME
# that isn't in the system-dir blacklist (config, keys, skills, memory,
# sessions, cache, logs, etc.).
pull_profile_outputs() {
    local profile="${1:-$(active_profile_name)}"
    [ -z "$profile" ] && die "no profile given and no active profile set"

    local volume_path
    if [ "$profile" = "default" ]; then
        volume_path="/h"
    else
        volume_path="/h/profiles/${profile}"
    fi

    local host_path="${SCRIPT_DIR}/workspace/${profile}"
    mkdir -p "$host_path"

    # System dirs/files hermes manages — do NOT pull these to host.
    local excludes=(
        ".env" "config.yaml" "SOUL.md" ".hermes_history" ".update_check"
        ".clean_shutdown" ".skills_prompt_snapshot.json" "auth.json" "auth.lock"
        "active_profile" "channel_directory.json" "gateway_state.json" "gateway.pid"
        "models_dev_cache.json" "state.db" "state.db-shm" "state.db-wal"
        "sessions" "memories" "skills" "cron" "logs" "cache" "platforms"
        "bin" "home" "plans" "skins" "profiles" "workspace"
    )
    local rsync_excludes=""
    for e in "${excludes[@]}"; do
        rsync_excludes="${rsync_excludes} --exclude=${e}"
    done

    info "pulling outputs from ${volume_path} → ${host_path}"
    docker run --rm --user 1000:1000 \
        -v "$(volume_name):/h:ro" \
        -v "${host_path}:/dst" alpine sh -c "
            apk add -q rsync >/dev/null 2>&1 || true
            if command -v rsync >/dev/null 2>&1; then
                rsync -a ${rsync_excludes} ${volume_path}/ /dst/
            else
                # Fallback without rsync — cp everything then rm the excludes
                cp -rn ${volume_path}/. /dst/ 2>/dev/null || true
                for e in ${excludes[*]}; do rm -rf /dst/\$e 2>/dev/null; done
            fi
        " 2>&1
    ok "pulled → ./workspace/${profile}/"
    ls -la "$host_path" | tail -n +2
}

# --- preflight ---
[ -f docker-compose.yml ] || die "docker-compose.yml not found (run from the docker-hermes dir)"

cmd="${1:-help}"
shift || true

case "$cmd" in

    # ---- agent (TUI) ----
    open|agent|run)
        # Interactive terminal UI. Exits cleanly when you Ctrl-D out.
        exec "${COMPOSE[@]}" run --rm hermes "$@"
        ;;

    shell|sh|bash)
        # Root-less shell inside a fresh container (for poking around).
        exec "${COMPOSE[@]}" run --rm --entrypoint /bin/bash hermes
        ;;

    sessions|ls-sessions)
        # List recent sessions from the volume. Sessions are stored as
        # ~/.hermes/sessions/session_<id>.json — strip prefix/suffix to get
        # the id that `hermes --resume` expects.
        volume="$(basename "$SCRIPT_DIR" | tr '[:upper:]' '[:lower:]' | tr -dc 'a-z0-9_-')_hermes-home"
        limit="${1:-15}"
        docker run --rm --user 1000:1000 -v "${volume}:/h" alpine sh -c "
            ls -t /h/sessions/ 2>/dev/null \
              | grep -E '^session_[0-9_a-f]+\\.json$' \
              | head -${limit} \
              | sed 's/^session_//; s/\\.json\$//' \
              | awk -F_ '{
                  date=substr(\$1,1,4)\"-\"substr(\$1,5,2)\"-\"substr(\$1,7,2);
                  time=substr(\$2,1,2)\":\"substr(\$2,3,2)\":\"substr(\$2,5,2);
                  printf \"  %s %s  %s\\n\", date, time, \$0
                }'
        "
        ;;

    resume)
        # Resume a hermes session. With no arg, picks the most recent one.
        # With an id, resumes that specific session.
        volume="$(basename "$SCRIPT_DIR" | tr '[:upper:]' '[:lower:]' | tr -dc 'a-z0-9_-')_hermes-home"
        if [ $# -eq 0 ]; then
            sid="$(docker run --rm --user 1000:1000 -v "${volume}:/h" alpine sh -c "
                ls -t /h/sessions/ 2>/dev/null \
                  | grep -E '^session_[0-9_a-f]+\\.json$' \
                  | head -1 \
                  | sed 's/^session_//; s/\\.json\$//'
            ")"
            [ -z "$sid" ] && die "no sessions found in volume"
            info "resuming latest: $sid"
        else
            sid="$1"
            shift
        fi
        exec "${COMPOSE[@]}" run --rm hermes --resume "$sid" "$@"
        ;;

    # ---- gateway (messaging listener) ----
    start|up)
        "${COMPOSE[@]}" up -d gateway
        ok "gateway started"
        "${COMPOSE[@]}" ps gateway
        ;;

    stop|down)
        "${COMPOSE[@]}" stop gateway
        ok "gateway stopped"
        ;;

    restart)
        "${COMPOSE[@]}" restart gateway
        ok "gateway restarted"
        ;;

    status|ps)
        "${COMPOSE[@]}" ps
        ;;

    logs|log|tail)
        # Default: follow. Pass `--no-follow` or a line count for one-shot.
        if [ $# -eq 0 ]; then
            exec "${COMPOSE[@]}" logs -f gateway
        else
            exec "${COMPOSE[@]}" logs "$@" gateway
        fi
        ;;

    # ---- config ----
    setup)
        # First-time or re-run config wizard. Writes to the persistent volume.
        exec "${COMPOSE[@]}" run --rm hermes setup
        ;;

    gateway-setup|gsetup)
        exec "${COMPOSE[@]}" run --rm hermes gateway setup
        ;;

    config)
        exec "${COMPOSE[@]}" run --rm hermes config "$@"
        ;;

    edit)
        # Edit hermes's config.yaml (model, tools, personalities — not keys).
        # Respects EDITOR env var (default: vi). E.g. EDITOR=nano ./hermes edit
        edit_in_volume "/h/config.yaml"
        maybe_restart_gateway
        ;;

    env|keys)
        # Edit the volume's .env where API keys live.
        # Respects EDITOR env var (default: vi). E.g. EDITOR=nano ./hermes env
        edit_in_volume "/h/.env"
        maybe_restart_gateway
        ;;

    pull)
        # Top-level shortcut for `./hermes profile pull [name]`. Syncs hermes
        # skill outputs (PDFs, reports, etc.) from the volume to the host's
        # ./workspace/<profile>/ dir. Run after the agent generates files.
        pull_profile_outputs "${1:-}"
        exit 0
        ;;

    cat-env|show-env)
        # Print the volume's .env with values redacted — useful for verifying
        # which keys exist without leaking values to a transcript.
        volume="$(basename "$SCRIPT_DIR" | tr '[:upper:]' '[:lower:]' | tr -dc 'a-z0-9_-')_hermes-home"
        exec docker run --rm --user 1000:1000 -v "${volume}:/h" alpine \
            sh -c "sed -E 's/^([A-Z_]+)=.+/\\1=<redacted>/' /h/.env"
        ;;

    # ---- profiles ----
    profile|profiles)
        # Forward to `hermes profile …` for list/create/use/delete/etc.
        # e.g. ./hermes profile list   ./hermes profile create researcher
        #
        # `profile delete` prompts for the name via stdin, which doesn't
        # flow cleanly through `docker compose run` in all environments.
        # Nudge users to pass --yes explicitly when deleting.
        if [ "${1:-}" = "delete" ] && ! printf '%s\n' "$@" | grep -qE '^--yes$|^-y$'; then
            info "\`profile delete\` needs --yes when run via the wrapper"
            info "  re-run: ./hermes profile delete $2 --yes"
            exit 1
        fi
        # `profile workspace [name]` — local extension: wires a profile's
        # terminal.cwd to the host-bound ./workspace/<name>/ directory so
        # shell-generated files land on the host.
        if [ "${1:-}" = "workspace" ]; then
            shift
            setup_profile_workspace "${1:-}"
            exit 0
        fi
        # `profile pull [name]` — copy hermes-skill outputs (PDFs, reports,
        # downloads) from the volume's profile dir to ./workspace/<name>/.
        # Needed because skills write to HERMES_HOME regardless of
        # terminal.cwd. Safe to re-run; excludes all system state.
        if [ "${1:-}" = "pull" ]; then
            shift
            pull_profile_outputs "${1:-}"
            exit 0
        fi
        # `profile create <name>` — after hermes finishes creating the profile,
        # auto-wire its workspace to ./workspace/<name>/ so day-one writes
        # land on the host instead of inside the volume.
        if [ "${1:-}" = "create" ]; then
            "${COMPOSE[@]}" run --rm hermes profile "$@"
            rc=$?
            if [ $rc -eq 0 ]; then
                # Last non-flag argument is the profile name
                new_name=""
                for arg in "$@"; do
                    case "$arg" in --*) ;; *) new_name="$arg" ;; esac
                done
                [ -n "$new_name" ] && [ "$new_name" != "create" ] && setup_profile_workspace "$new_name"
            fi
            exit $rc
        fi
        exec "${COMPOSE[@]}" run --rm hermes profile "$@"
        ;;

    # ---- souls (per-profile SOUL.md) ----
    soul|souls)
        # Sub-dispatch on the next arg. SOUL.md is the profile-level persona
        # prompt. Each profile has its own; this command only touches that
        # one file, leaving the profile's config.yaml and .env intact.
        sub="${1:-edit}"; shift || true
        case "$sub" in
            edit|"")
                profile="${1:-$(active_profile_name)}"
                path="$(soul_path_in_volume "$profile")"
                edit_in_volume "${path}" "mkdir -p \$(dirname ${path})"
                maybe_restart_gateway
                ;;
            show|cat)
                profile="${1:-$(active_profile_name)}"
                path="$(soul_path_in_volume "$profile")"
                exec docker run --rm --user 1000:1000 -v "$(volume_name):/h" alpine cat "${path}"
                ;;
            import)
                file="${1:-}"
                profile="${2:-$(active_profile_name)}"
                [ -z "$file" ] && die "usage: ./hermes soul import <file> [profile]"
                [ -f "$file" ] || die "no such file: $file"
                path="$(soul_path_in_volume "$profile")"
                docker run --rm -i --user 1000:1000 -v "$(volume_name):/h" alpine \
                    sh -c "mkdir -p \$(dirname ${path}) && cat > ${path}" < "$file"
                ok "imported → ${path} (profile: ${profile})"
                maybe_restart_gateway
                ;;
            export)
                file="${1:-}"
                profile="${2:-$(active_profile_name)}"
                [ -z "$file" ] && die "usage: ./hermes soul export <file> [profile]"
                path="$(soul_path_in_volume "$profile")"
                docker run --rm --user 1000:1000 -v "$(volume_name):/h" alpine cat "${path}" > "$file" \
                    || die "profile '${profile}' has no SOUL.md yet"
                ok "exported ${path} → ${file}"
                ;;
            *)
                die "unknown soul subcommand: $sub  (try: edit, show, import, export)"
                ;;
        esac
        ;;

    # ---- lifecycle ----
    build)
        "${COMPOSE[@]}" build "$@"
        ok "image built"
        ;;

    rebuild)
        "${COMPOSE[@]}" build --no-cache "$@"
        ok "image rebuilt from scratch"
        ;;

    update|pull)
        # Re-clone hermes-agent at current HERMES_REF without touching the volume.
        info "rebuilding with --no-cache to pull latest hermes-agent"
        "${COMPOSE[@]}" build --no-cache
        # Clear hermes's cached "N commits behind" result — it's memoized in
        # the volume and will otherwise keep reporting the pre-update value
        # until its TTL expires. The cache is guaranteed stale after a rebuild.
        volume="$(basename "$SCRIPT_DIR" | tr '[:upper:]' '[:lower:]' | tr -dc 'a-z0-9_-')_hermes-home"
        docker run --rm -v "${volume}:/h" alpine rm -f /h/.update_check 2>/dev/null || true
        ok "updated (your ~/.hermes volume is untouched; update cache cleared)"
        ;;

    clean)
        # Stop everything but keep the volume.
        "${COMPOSE[@]}" down
        ok "containers removed (volume kept)"
        ;;

    nuke)
        # Delete containers AND the hermes-home volume. Destructive.
        echo -n "${Y}This deletes the hermes-home volume (all skills/config). Type 'yes' to confirm:${N} "
        read -r ans
        [ "$ans" = "yes" ] || { info "aborted"; exit 1; }
        "${COMPOSE[@]}" down -v
        ok "all gone"
        ;;

    # ---- help ----
    help|-h|--help|"")
        cat <<EOF
${B}hermes${N} — docker-compose wrapper for hermes-agent

${B}agent:${N}
  ${G}open${N}              launch the interactive terminal UI
  ${G}resume${N} [id]       resume a session (no id → most recent)
  ${G}sessions${N} [N]      list the N most recent sessions (default 15)
  ${G}shell${N}             bash shell inside a one-off container
  ${G}config${N} [args]     run \`hermes config …\` in a one-off container
  ${G}edit${N}              open config.yaml (uses \$EDITOR, default: vi)
  ${G}env${N}               edit the volume's .env (uses \$EDITOR, default: vi)
  ${G}cat-env${N}           list which keys exist (values redacted)
  ${G}setup${N}             run the first-time setup wizard
  ${G}gsetup${N}            run the gateway-specific setup wizard

${B}profiles / souls (multi-persona):${N}
  ${G}profile${N} [args]     forward to \`hermes profile …\` (list/create/use/…)
  ${G}profile workspace${N} [name]   wire a profile's cwd to ./workspace/<name>/
  ${G}pull${N} [profile]     sync hermes skill outputs (PDFs, reports) to host
                       (same as \`./hermes profile pull [name]\`)
  ${G}soul${N} [profile]     edit SOUL.md (uses \$EDITOR, active profile if omitted)
  ${G}soul show${N} [prof]   cat SOUL.md to stdout
  ${G}soul import${N} <f> [prof]   replace SOUL.md from host file
  ${G}soul export${N} <f> [prof]   save SOUL.md to host file

${B}gateway (background messaging listener):${N}
  ${G}start${N}             bring gateway up in background
  ${G}stop${N}              stop the gateway
  ${G}restart${N}           restart the gateway
  ${G}status${N}            show running services
  ${G}logs${N} [args]       follow gateway logs (pass extra args verbatim)

${B}image / volume:${N}
  ${G}build${N}             build the image (cached)
  ${G}rebuild${N}           build with --no-cache
  ${G}update${N}            re-clone latest hermes-agent and rebuild
  ${G}clean${N}             remove containers (keep the hermes-home volume)
  ${G}nuke${N}              remove containers AND the volume (destructive)

${B}tip:${N} set ${G}EDITOR=nano${N} to use nano instead of vi for edit/env/soul commands.
     e.g. ${DIM}EDITOR=nano ./hermes edit${N}   or   ${DIM}export EDITOR=nano${N} (sticky for the shell session)

Run ${DIM}./hermes <command> --help${N} for docker compose's help on a given verb.
EOF
        ;;

    *)
        die "unknown command: $cmd  (try: ./hermes help)"
        ;;
esac
